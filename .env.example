# Azure OpenAI settings for the lecture chat client.
# Copy this file to .env.local for local-only settings, or export the values in your shell.

MCP_DEMO_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
MCP_DEMO_AZURE_OPENAI_API_KEY=replace-me
MCP_DEMO_AZURE_OPENAI_DEPLOYMENT=model-router
MCP_DEMO_AZURE_OPENAI_API_VERSION=2024-10-21
# Set to true if you want the Python client to mirror the .NET app's DefaultAzureCredential flow.
MCP_DEMO_AZURE_OPENAI_USE_DEFAULT_CREDENTIAL=false
